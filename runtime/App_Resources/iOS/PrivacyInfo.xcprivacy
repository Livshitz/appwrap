<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Apple Privacy Manifest. REQUIRED for App Store upload since May 2024 (hard reject otherwise).
  Declares the "required-reason APIs" the appwrap shell + NativeScript runtime touch, none of which
  are used for tracking:
    - UserDefaults (CA92.1)   — kit.storage / ApplicationSettings (NSUserDefaults)
    - FileTimestamp (C617.1)  — NativeScript reads bundle/app file metadata at runtime
    - SystemBootTime (35F9.1) — NativeScript timers/uptime
    - DiskSpace (E174.1)      — NativeScript file I/O
  NSPrivacyTracking is false and no data types are collected BY THE SHELL. If your PWA collects user
  data (account, analytics, location) or uses tracking, add the matching NSPrivacyCollectedDataTypes /
  NSPrivacyTracking entries here — see tracking-analytics + store-readiness.
-->
<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategorySystemBootTime</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>35F9.1</string>
			</array>
		</dict>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryDiskSpace</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>E174.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
