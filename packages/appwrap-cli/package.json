{
  "name": "@livx.cc/appwrap",
  "version": "0.21.0",
  "description": "Wrap any PWA into a native app with native capabilities (appwrap runtime + @livx.cc/native-kit).",
  "license": "MIT",
  "author": "Elya Livshitz",
  "homepage": "https://github.com/Livshitz/appwrap#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Livshitz/appwrap.git",
    "directory": "packages/appwrap-cli"
  },
  "bugs": {
    "url": "https://github.com/Livshitz/appwrap/issues"
  },
  "keywords": [
    "pwa",
    "native",
    "webview",
    "nativescript",
    "appwrap",
    "cli",
    "ios",
    "android"
  ],
  "type": "module",
  "bin": {
    "appwrap": "src/cli.ts"
  },
  "exports": {
    ".": "./src/config.ts",
    "./config": "./src/config.ts",
    "./cli": "./src/cli.ts"
  },
  "files": [
    "src",
    "runtime",
    "templates",
    "scripts/stage-assets.mjs"
  ],
  "scripts": {
    "prepack": "node scripts/stage-assets.mjs",
    "postpack": "rm -rf runtime templates"
  },
  "publishConfig": {
    "access": "public"
  }
}
