{
  "name": "@livx.cc/native-kit",
  "version": "0.26.0",
  "description": "Isomorphic native-capabilities kit for PWAs — same API in browser and in an appwrap native shell. Zero dependencies.",
  "license": "MIT",
  "author": "Elya Livshitz",
  "homepage": "https://github.com/Livshitz/appwrap#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Livshitz/appwrap.git",
    "directory": "packages/native-kit"
  },
  "bugs": {
    "url": "https://github.com/Livshitz/appwrap/issues"
  },
  "keywords": [
    "pwa",
    "native",
    "webview",
    "nativescript",
    "appwrap",
    "isomorphic",
    "ios",
    "android"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --format=esm && bun build src/index.ts --outfile=dist/native-kit.iife.js --format=iife --global-name=NativeKitLib"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
