# appwrap fastlane — emitted by `appwrap init` into native/fastlane/. App id + team are stamped
# from the appwrap config. Auth is App Store Connect API key only (headless-safe; no interactive Apple ID).

default_platform(:ios)

APP_ID = '__APP_ID__'.freeze
TEAM_ID = '__TEAM_ID__'.freeze

# Run `ns prepare` (which shells out to `pod install`) with a SANITIZED gem env.
#
# Why: fastlane runs under its own Ruby and exports GEM_HOME/GEM_PATH into every child process. On a
# Mac, NativeScript's `pod` is the system one (`/usr/local/bin/pod`, shebang-pinned to Ruby 2.6, whose
# CocoaPods lives in /Library/Ruby/Gems/2.6.0). The inherited GEM_HOME redirects its gem lookup to
# fastlane's Ruby dir → `can't find gem cocoapods (Gem::GemNotFoundException)` → NS prints
# `'arch install' command failed` (exit 127). Interactively `pod` works because no GEM_HOME is set.
#
# Fix: only when the active `pod` is that system-Ruby-2.6 binary, drop the leaked GEM_* vars so it
# falls back to its own default gem dir. CI runners use a self-managed Ruby (setup-ruby) whose `pod`
# is NOT the system 2.6 one, so the env is left untouched there — no behavior change on CI.
def appwrap_prepare_ios
  prepare = "cd '#{File.expand_path('..', __dir__)}' && ns prepare ios --release"
  pod = `command -v pod`.strip
  system_pod = !pod.empty? && File.exist?(pod) &&
               File.read(pod, 256).include?('Ruby.framework/Versions/2.6')
  unless system_pod
    sh(prepare)
    return
  end
  leaked = %w[GEM_HOME GEM_PATH RUBYLIB RUBYOPT BUNDLE_GEMFILE BUNDLE_BIN_PATH]
  saved = {}
  leaked.each { |k| saved[k] = ENV[k]; ENV.delete(k) }
  begin
    sh(prepare)
  ensure
    saved.each { |k, v| ENV[k] = v unless v.nil? }
  end
end

# Shared archive-and-sign sequence for BOTH the TestFlight (:beta) and App Store (:release) lanes.
# Returns the ASC API-key object so each lane can reuse it for its final upload step — the lanes
# differ ONLY in that final step (upload_to_testflight vs upload_to_app_store). Keep the recipe here,
# not duplicated per-lane.
def appwrap_archive_and_sign_ios
  setup_ci # on CI: provisions a temporary unlocked keychain so codesign can use the match cert

  api_key = app_store_connect_api_key(
    key_id: ENV['ASC_KEY_ID'],
    issuer_id: ENV['ASC_ISSUER_ID'],
    key_content: ENV['ASC_KEY_P8'],
    is_key_content_base64: true
  )

  # readonly: certs/profiles must be seeded once via `fastlane match appstore` (see workflow header).
  match(type: 'appstore', readonly: true, app_identifier: APP_ID,
        git_url: ENV['MATCH_GIT_URL'], api_key: api_key)

  # NativeScript prepares the Xcode project inside the wrapper dir (native/ = parent of fastlane/).
  # Wrapped to sanitize the gem env so the system `pod` can find CocoaPods (see appwrap_prepare_ios).
  appwrap_prepare_ios

  # NS defaults the project to automatic signing → archive can't find a profile. Pin manual signing
  # to the match-provided App Store profile (name exported by match into ENV).
  profile = ENV["sigh_#{APP_ID}_appstore_profile-name"] || "match AppStore #{APP_ID}"
  update_code_signing_settings(
    use_automatic_signing: false,
    path: 'platforms/ios/native.xcodeproj',
    team_id: TEAM_ID,
    bundle_identifier: APP_ID,
    code_sign_identity: 'Apple Distribution',
    profile_name: profile
  )

  build_app(
    workspace: 'platforms/ios/native.xcworkspace',
    scheme: 'native',
    export_method: 'app-store',
    export_options: { provisioningProfiles: { APP_ID => profile } }
  )

  api_key
end

# Restore the login keychain as the system default and drop fastlane's temp keychain. `setup_ci`/`match`
# create `fastlane_tmp_keychain` and point the default keychain at it; if a lane dies mid-run before
# fastlane's own teardown, that stray keychain is left as the DEFAULT — so macOS (com.apple.iCloudHelper
# etc.) keeps prompting for its password forever. CI runners are ephemeral so this is a no-op there;
# locally it prevents the recurring keychain prompt. Best-effort: never fail the lane on cleanup.
def appwrap_keychain_cleanup
  login = File.expand_path('~/Library/Keychains/login.keychain-db')
  return unless File.exist?(login)
  sh("security default-keychain -s '#{login}'", error_callback: ->(_) {})
  sh('security delete-keychain ~/Library/Keychains/fastlane_tmp_keychain-db 2>/dev/null || true',
     error_callback: ->(_) {})
rescue StandardError => e
  UI.message("keychain cleanup skipped: #{e}")
end

platform :ios do
  after_all { appwrap_keychain_cleanup }
  error { |_lane, _exception| appwrap_keychain_cleanup }

  desc 'Build the NativeScript wrapper and upload to TestFlight'
  lane :beta do
    api_key = appwrap_archive_and_sign_ios

    # Wait for App Store Connect to finish processing and FAIL if it doesn't — Apple can accept the
    # upload yet silently drop the build (e.g. an out-of-range CFBundleVersion). skip:true hides that.
    # APPWRAP_TF_WAIT_TIMEOUT (seconds) tunes the wait: real builds can exceed 30 min under Apple
    # processing load and crash the lane (BuildWatcher exceeded) — default to 1h, raise it if needed.
    # Guard BOTH unset (nil) and empty/blank env: nil.to_i and "".to_i are 0, which would crash the
    # lane instantly (BuildWatcher exceeded '0'). Only a positive integer overrides the 3600 default.
    tf_wait_env = ENV['APPWRAP_TF_WAIT_TIMEOUT'].to_s.strip
    tf_wait_timeout = tf_wait_env.to_i > 0 ? tf_wait_env.to_i : 3600
    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: false, wait_processing_timeout_duration: tf_wait_timeout)
  end

  desc 'Build the NativeScript wrapper and promote the binary to the App Store (production).'
  lane :release do
    api_key = appwrap_archive_and_sign_ios

    # Binary-only promote: the listing/metadata/screenshots/IAP stay in App Store Connect — this lane
    # only ships the signed binary. SAFE by default: no review submit, no automatic release, headless
    # (force: true → no HTML preview). Set APPWRAP_SUBMIT_FOR_REVIEW=true to also submit for review.
    # Guard BOTH unset (nil) and blank env the same way as APPWRAP_TF_WAIT_TIMEOUT above.
    submit_for_review = ENV['APPWRAP_SUBMIT_FOR_REVIEW'].to_s.strip.downcase == 'true'
    upload_to_app_store(
      api_key: api_key,
      submit_for_review: submit_for_review,
      automatic_release: false,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      force: true
    )
  end
end

platform :android do
  desc 'Upload the appwrap-built AAB to Play (internal track). Build it first with `appwrap build android --release --aab`.'
  lane :beta do
    upload_to_play_store(
      track: 'internal',
      aab: 'platforms/android/app/build/outputs/bundle/release/app-release.aab',
      json_key_data: ENV['PLAY_SERVICE_ACCOUNT_JSON'],
      # Binary-only upload: listing/screenshots are managed in the Play Console, not CI.
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
